# Django Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,meshlogiq.local,auth.meshlogiq.local,auth-gateway

# CSRF trusted origins — required when Django is behind a TLS-terminating reverse proxy (Traefik)
CSRF_TRUSTED_ORIGINS=https://auth.meshlogiq.local,https://meshlogiq.local

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://meshlogiq.local
CORS_ALLOW_CREDENTIALS=true

# Keycloak Configuration
KEYCLOAK_URL=https://sso.meshlogiq.local
KEYCLOAK_REALM=meshlogiq
KEYCLOAK_CLIENT_ID=meshlogiq-backend
KEYCLOAK_CLIENT_SECRET=your-client-secret
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin-password

# Database
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=meshlogiq
DATABASE_USER=meshlogiq
DATABASE_PASSWORD=mesh_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# FastAPI Settings
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Rate Limiting
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_BURST=20

# Token Lifespans
ACCESS_TOKEN_LIFETIME=15
REFRESH_TOKEN_LIFETIME=1440

# Admin Settings
DJANGO_ADMIN_URL=admin/