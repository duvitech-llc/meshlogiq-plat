# --- Core admin bootstrap (first run only) ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=changeme

# --- DB connection (matches keycloak-db.env) ---
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://db:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloakpass

# --- Reverse proxy + hostnames (Traefik terminates TLS) ---
KC_PROXY=edge
KC_HTTP_ENABLED=true
KC_HOSTNAME=sso.meshlogiq.local
KC_HOSTNAME_URL=https://sso.meshlogiq.local
KC_HOSTNAME_ADMIN_URL=https://sso.meshlogiq.local

# Optional: reduce noisy metrics/health endpoints exposure; keep true for dev
KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=false